---
import { getLangFromUrl, useTranslations, useTranslatedPath } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);
---

<section class="statement-section" aria-label="Author statement">
  <div class="statement-inner reveal">
    <blockquote class="statement-quote">
      "{t('statement.text')}"
    </blockquote>
    <p class="statement-attribution">{t('statement.author')}</p>
    <a href={translatePath('/about')} class="btn btn-ghost">{t('statement.cta')}</a>
  </div>
</section>
