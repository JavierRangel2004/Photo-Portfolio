---
import { getRandomPhotosFromAllCategories } from '../lib/photos';
import type { Photo } from '../lib/photos';
import PhotoCard from './PhotoCard.astro';
import { getLangFromUrl, useTranslations, useTranslatedPath } from '../i18n/utils';

const photos: Photo[] = getRandomPhotosFromAllCategories(5);

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);
---

<section class="featured-section" id="home-glance" aria-label="Selected works">
  <div class="featured-header reveal">
    <div class="section-heading">
      <p class="section-eyebrow">{t('featured.eyebrow')}</p>
      <h2 class="section-title">{t('featured.title')}</h2>
      <p class="section-subtitle">{t('featured.subtitle')}</p>
    </div>
    <a href={translatePath('/gallery')} class="view-all">{t('featured.viewAll')}</a>
  </div>

  <div class="masonry-gallery masonry-gallery--featured">
    {photos.map((photo, i) => (
      <div
        class="masonry-item reveal"
        style={`transition-delay: ${(i % 4) * 0.08}s`}
      >
        <PhotoCard
          photo={photo}
          lightboxGroup="home-featured"
          loading={i < 6 ? 'eager' : 'lazy'}
        />
      </div>
    ))}
  </div>
</section>
