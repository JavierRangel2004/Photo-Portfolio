---
import { Image } from 'astro:assets';
import { getRandomPhotosByCategory, getCategories } from '../lib/photos';
import { getLangFromUrl, useTranslations, useTranslatedPath } from '../i18n/utils';

const categories = getCategories();

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);

const categoryMeta: Record<string, { label: string; description: string }> = {
  portraits: { label: t('category.portraits'), description: t('categories.desc.portraits') },
  city:       { label: t('category.city'),      description: t('categories.desc.city') },
  concert:    { label: t('category.concert'),   description: t('categories.desc.concert') },
  product:    { label: t('category.product'),   description: t('categories.desc.product') },
  nature:     { label: t('category.nature'),    description: t('categories.desc.nature') },
  creativity: { label: t('category.creativity'),  description: t('categories.desc.creativity') },
};

const categoryData = categories.map(cat => {
  const photos = getRandomPhotosByCategory(cat, 1);
  const cover = photos[0];
  const meta = categoryMeta[cat] || { label: cat, description: '' };
  return { ...meta, slug: cat, cover };
});
---

<section class="categories-section" id="home-themes" aria-label="Photography categories">
  <div class="categories-header reveal">
    <div class="section-heading">
      <p class="section-eyebrow">{t('categories.eyebrow')}</p>
      <h2 class="section-title">{t('categories.title')}</h2>
      <p class="section-subtitle">{t('categories.subtitle')}</p>
    </div>
  </div>

  <div class="categories-grid">
    {categoryData.map((cat, i) => (
      <a
        href={`${translatePath('/gallery')}?category=${cat.slug}`}
        class="category-card reveal"
        style={`transition-delay: ${i * 0.06}s`}
        aria-labelledby={`category-card-name-${cat.slug}`}
        aria-describedby={`category-card-desc-${cat.slug}`}
      >
        {cat.cover && (
          <Image
            src={cat.cover.src}
            alt={lang === 'es' ? `Fotografía de ${cat.label.toLowerCase()}` : `${cat.label} photography`}
            width={cat.cover.width}
            height={cat.cover.height}
            loading="lazy"
          />
        )}
        <div class="category-card-body">
          <span id={`category-card-name-${cat.slug}`} class="category-card-name">{cat.label}</span>
          <span id={`category-card-desc-${cat.slug}`} class="category-card-count">{cat.description}</span>
        </div>
      </a>
    ))}
  </div>
</section>
