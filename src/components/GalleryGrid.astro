---
import PhotoCard from './PhotoCard.astro';
import type { Photo } from '../lib/photos';

interface Props {
  photos: Photo[];
  initialCategory?: string;
}

const { photos, initialCategory = 'all' } = Astro.props;
---

<div class="masonry-gallery" id="masonry-gallery">
  {photos.map((photo) => {
    const isVisible = initialCategory === 'all' || photo.category === initialCategory;
    return (
      <div
        class="masonry-item"
        data-category={photo.category}
        style={isVisible ? '' : 'display: none;'}
      >
        <PhotoCard photo={photo} lightboxGroup="archive" />
      </div>
    );
  })}
</div>
