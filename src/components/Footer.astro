---
const currentYear = new Date().getFullYear();
const siteTitle = "JRMGraphy";
const email = "inspecjrm@gmail.com";
const instagram = "https://www.instagram.com/JRM_Graphy";
---

<footer class="site-footer">
  <div class="footer-brand">
    <img src="/assets/images/logo.jpg" alt="JRMGraphy Logo">
  </div>
  <div class="footer-contact-info">
    <a href={`mailto:${email}`}>
      <i class="fa fa-envelope fa-lg" aria-hidden="true"></i>
      <span>Email</span>
    </a>
    <a href={instagram} target="_blank" rel="noopener noreferrer">
      <i class="fab fa-instagram fa-lg" aria-hidden="true"></i>
      <span>Instagram</span>
    </a>
  </div>
  <div class="footer-links">
    <a href="/">Home</a> |
    <a href="/gallery">Gallery</a> |
    <a href="/about">About</a> |
    <a href="/contact">Contact</a>
  </div>
  <div class="footer-copyright">
    <p>&copy; {currentYear} {siteTitle}. All rights reserved.</p>
  </div>
</footer>

