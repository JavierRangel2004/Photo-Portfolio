---
import { getRandomPhotosByCategory } from '../lib/photos';

// Pick a strong hero image from portraits or city
const heroPhoto = getRandomPhotosByCategory('portraits', 1)[0] 
               || getRandomPhotosByCategory('city', 1)[0];
---

<section class="hero" aria-label="Hero">
  <div class="hero-bg" id="hero-bg">
    {heroPhoto && (
      <img
        src={heroPhoto.src}
        alt="JRMGraphy hero"
        width={heroPhoto.width || 1920}
        height={heroPhoto.height || 1280}
        loading="eager"
        fetchpriority="high"
        id="hero-img"
      />
    )}
  </div>
  <div class="hero-overlay"></div>

  <div class="hero-content">
    <p class="hero-eyebrow">Mexico City · Photography</p>
    <h1 class="hero-title">JRMGraphy</h1>
    <p class="hero-subtitle">A curated view of presence, city, and light.</p>

    <div class="hero-actions">
      <a href="/gallery" class="btn btn-primary">View Archive</a>
      <a href="/contact" class="btn btn-ghost">Get in Touch</a>
    </div>
  </div>

  <a class="hero-scroll" id="hero-scroll" href="#home-themes" aria-label="Explore themes">
    <span class="hero-scroll-text">Explore themes</span>
    <span class="hero-scroll-icon" aria-hidden="true"></span>
  </a>
</section>

<script>
  // Subtle parallax on hero bg
  const heroBg = document.getElementById('hero-bg');
  if (heroBg && window.matchMedia('(prefers-reduced-motion: no-preference)').matches) {
    window.addEventListener('scroll', () => {
      const scrolled = window.scrollY;
      heroBg.style.transform = `translateY(${scrolled * 0.35}px)`;
    }, { passive: true });
  }

  // Small zoom-out on load for cinematic feel
  const heroImg = document.getElementById('hero-img') as HTMLImageElement | null;
  if (heroImg) {
    heroImg.addEventListener('load', () => heroImg.classList.add('loaded'));
    if (heroImg.complete) heroImg.classList.add('loaded');
  }

  const heroScroll = document.getElementById('hero-scroll');
  if (heroScroll) {
    const toggleHeroScroll = () => {
      const shouldHide = window.scrollY > 24;
      heroScroll.classList.toggle('is-hidden', shouldHide);
      heroScroll.classList.toggle('is-visible', !shouldHide);
    };

    requestAnimationFrame(toggleHeroScroll);
    window.addEventListener('scroll', toggleHeroScroll, { passive: true });
  }
</script>

<style>
  .hero-actions {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: 1rem;
    margin-top: 2rem;
    opacity: 0;
    transform: translateY(16px);
    animation: reveal 0.7s cubic-bezier(0.16, 1, 0.3, 1) 0.8s forwards;
  }

  @media (max-width: 768px) {
    .hero-content {
      text-align: center;
    }

    .hero-subtitle {
      margin-inline: auto;
    }

    .hero-actions {
      flex-direction: column;
      width: 100%;
    }
  }
</style>
