---
interface Props {
  photo: {
    id: string;
    category: string;
    src: string;
    date: string;
    sessionDate: string;
    originalName: string;
    width?: number;
    height?: number;
  };
  lightboxGroup?: string;
  loading?: 'eager' | 'lazy';
}

const {
  photo,
  lightboxGroup = 'default',
  loading = 'lazy',
} = Astro.props;

const orientation =
  !photo.width || !photo.height
    ? 'landscape'
    : photo.width === photo.height
      ? 'square'
      : photo.width > photo.height
        ? 'landscape'
        : 'portrait';
---

<div
  class={`photo-card photo-card--${orientation}`}
  data-lightbox-src={photo.src}
  data-lightbox-cat={photo.category}
  data-lightbox-id={photo.id}
  data-lightbox-group={lightboxGroup}
  data-orientation={orientation}
  role="button"
  tabindex="0"
  aria-label={`View ${photo.category} photo`}
>
  <img
    src={photo.src}
    alt={`${photo.category} photography by JRMGraphy`}
    width={photo.width}
    height={photo.height}
    loading={loading}
  />
  <div class="photo-card-overlay"></div>
  <span class="photo-card-cat">{photo.category}</span>
</div>
