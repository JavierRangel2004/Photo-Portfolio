---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

interface Props {
  categories: string[];
  currentCategory?: string;
}

const { categories, currentCategory = 'all' } = Astro.props;

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const categoryMap: Record<string, any> = {
  portraits: { es: 'Retratos', en: 'Portraits' },
  city: { es: 'Ciudad', en: 'City' },
  concert: { es: 'Conciertos', en: 'Concert' },
  nature: { es: 'Naturaleza', en: 'Nature' },
  product: { es: 'Producto', en: 'Product' },
  creativity: { es: 'Creatividad', en: 'Creativity' },
};
---

<div class="category-dropdown-wrapper">
  <label for="categoryFilter" class="form-label">{t('gallery.filter')}</label>
  <select id="categoryFilter" class="form-select d-inline-block w-auto">
    <option value="all" selected={currentCategory === 'all'}>{t('gallery.all')}</option>
    {categories.map((category) => {
      const displayCategory = categoryMap[category]?.[lang] || category;
      return (
        <option 
          value={category}
          selected={currentCategory === category}
        >
          {displayCategory}
        </option>
      )
    })}
  </select>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const categoryFilter = document.getElementById('categoryFilter') as HTMLSelectElement | null;
    if (!categoryFilter) return;
    
    // Obtener todas las fotos usando data-category (carrusel o gallery)
    // Seleccionar solo las fotos (slides del carrusel o items de la gallery), no otros elementos
    const allPhotoSlides = document.querySelectorAll<HTMLElement>('.home-carousel-slide[data-category], .masonry-item[data-category]');
    
    // Función para filtrar fotos
    const filterPhotos = (selectedCategory: string) => {
      allPhotoSlides.forEach(slide => {
        const slideCategory = slide.getAttribute('data-category');
        const shouldShow = selectedCategory === 'all' || 
                          slideCategory === selectedCategory;
        
        slide.style.display = shouldShow ? '' : 'none';
      });
      
      // Actualizar URL sin recargar usando History API
      const url = new URL(window.location.href);
      if (selectedCategory === 'all') {
        url.searchParams.delete('category');
      } else {
        url.searchParams.set('category', selectedCategory);
      }
      window.history.pushState({ category: selectedCategory }, '', url);
    };
    
    // Event listener para el dropdown
    categoryFilter.addEventListener('change', (e) => {
      const selected = (e.currentTarget as HTMLSelectElement).value;
      filterPhotos(selected);
    });
    
    // Aplicar filtro inicial basado en la URL
    const urlParams = new URLSearchParams(window.location.search);
    const initialCategory = urlParams.get('category') || 'all';
    if (categoryFilter.value !== initialCategory) {
      categoryFilter.value = initialCategory;
    }
    filterPhotos(initialCategory);
    
    // Manejar navegación del navegador (back/forward)
    window.addEventListener('popstate', () => {
      const urlParams = new URLSearchParams(window.location.search);
      const category = urlParams.get('category') || 'all';
      categoryFilter.value = category;
      filterPhotos(category);
    });
  });
</script>

<style>
  .category-dropdown-wrapper {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    justify-content: center;
    margin: var(--space-xl) 0;
    flex-wrap: wrap;
  }
  
  .category-dropdown-wrapper .form-label {
    margin: 0;
    font-weight: var(--font-weight-medium);
    color: var(--color-primary);
    font-size: 1.1rem;
  }
  
  .category-dropdown-wrapper .form-select {
    min-width: 200px;
    border-radius: var(--radius-sm);
    border: 2px solid var(--color-background-alt);
    padding: var(--space-sm) var(--space-md);
    transition: border-color var(--transition-base), box-shadow var(--transition-base);
    font-family: var(--font-family);
    font-weight: var(--font-weight-medium);
  }
  
  .category-dropdown-wrapper .form-select:focus {
    border-color: var(--color-primary-light);
    box-shadow: 0 0 0 3px rgba(51, 51, 51, 0.1);
    outline: none;
  }
  
  @media (max-width: 576px) {
    .category-dropdown-wrapper {
      flex-direction: column;
      align-items: stretch;
    }
    
    .category-dropdown-wrapper .form-select {
      width: 100%;
    }
  }
</style>
