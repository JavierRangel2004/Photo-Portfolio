---
import PhotoCard from './PhotoCard.astro';
import type { Photo } from '../lib/photos';

interface Props {
  id: string;
  title: string;
  description: string;
  label: string;
  notes: { title: string; body: string }[];
  photos: Photo[];
  sectionIndex?: number;
  photoLimit?: number;
  archiveHref?: string;
  archiveLabel?: string;
  photoSizes?: string;
}

const {
  id,
  title,
  description,
  label,
  notes,
  photos,
  sectionIndex = 0,
  photoLimit = 6,
  archiveHref,
  archiveLabel,
  photoSizes,
} = Astro.props;

const visiblePhotos = typeof photoLimit === 'number' ? photos.slice(0, photoLimit) : photos;
---

<section class="portfolio-section scroll-mt-32 border-t border-white/10 bg-background" id={id}>
  <div class="portfolio-section-header mx-auto grid w-full max-w-7xl grid-cols-1 gap-8 bg-background px-6 lg:grid-cols-12 lg:items-start lg:gap-10">
    <div class="portfolio-section-head reveal flex flex-col items-start gap-4 lg:col-span-5">
      <p class="portfolio-section-label">{label}</p>
      <h2 class="portfolio-section-title max-w-5xl text-left font-heading text-4xl leading-[1.02] tracking-[-0.02em] text-text lg:text-5xl">
        {title}
      </h2>
      <p class="portfolio-section-description max-w-2xl text-left text-base leading-7 text-text-muted lg:max-w-[32rem]">
        {description}
      </p>
    </div>

    <div class="portfolio-notes grid grid-cols-1 gap-8 lg:col-span-7 lg:grid-cols-2">
      {notes.map((note, index) => (
        <article class="portfolio-note reveal border-0 bg-transparent p-0 shadow-none transition-none" style={`transition-delay: ${index * 0.08}s`}>
          <h3 class="mb-3 max-w-[14ch] font-heading text-2xl leading-[1.15] text-text lg:text-[2rem]">
            {note.title}
          </h3>
          <p class="max-w-[34ch] text-base leading-[1.9] text-text-muted">{note.body}</p>
        </article>
      ))}
    </div>
  </div>

  <div class="portfolio-gallery-grid mx-auto w-full max-w-7xl columns-1 gap-4 px-6 sm:columns-2 lg:columns-3">
    {visiblePhotos.map((photo, index) => (
      <div class="portfolio-gallery-item reveal mb-4 break-inside-avoid" style={`transition-delay: ${(index % 3) * 0.08}s`}>
        <PhotoCard
          photo={photo}
          lightboxGroup={id}
          label={label}
          loading={sectionIndex === 0 && index < 6 ? 'eager' : 'lazy'}
          sizes={photoSizes}
        />
      </div>
    ))}
  </div>

  {archiveHref && archiveLabel ? (
    <div class="portfolio-section-actions reveal">
      <a href={archiveHref} class="btn btn-ghost">{archiveLabel}</a>
    </div>
  ) : null}
</section>
