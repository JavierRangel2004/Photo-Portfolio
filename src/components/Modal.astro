---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<!-- Premium Lightbox — controlled by BaseLayout.astro script -->
<div class="lightbox" id="lightbox" role="dialog" aria-modal="true" aria-label="Photo viewer">
  <div class="lightbox-img-wrap">
    <img class="lightbox-img" id="lb-img" src="" alt="" />
  </div>

  <button class="lightbox-close" id="lb-close" aria-label={t('modal.close')}>&times;</button>

  <button class="lightbox-arrow prev" id="lb-prev" aria-label={t('modal.prev')}>
    <i class="fas fa-chevron-left"></i>
  </button>
  <button class="lightbox-arrow next" id="lb-next" aria-label={t('modal.next')}>
    <i class="fas fa-chevron-right"></i>
  </button>

  <div class="lightbox-meta">
    <span class="lightbox-category" id="lb-cat"></span>
    <span class="lightbox-counter" id="lb-count"></span>
  </div>
</div>
