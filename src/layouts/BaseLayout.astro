---
import { getLangFromUrl, getRouteWithoutLang } from '../i18n/utils';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Photography portfolio by Javier Rangel — Mexico City." } = Astro.props;
const siteTitle = "JRMGraphy";
const fullTitle = title === "Home" || title === "Inicio" ? siteTitle : `${title} — ${siteTitle}`;
const lang = getLangFromUrl(Astro.url);
const routeWithoutLang = getRouteWithoutLang(Astro.url);
const siteUrl = Astro.site ? Astro.site.origin : 'https://jrmgraphy.com';

const canonicalURL = new URL(`/${lang}${routeWithoutLang}`, siteUrl);
---

<!DOCTYPE html>
<html lang={lang}>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{fullTitle}</title>
  <meta name="description" content={description} />
  <meta name="theme-color" content="#0A0A0A" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <link rel="canonical" href={canonicalURL} />
  <link rel="alternate" hreflang="es" href={`${siteUrl}/es${routeWithoutLang}`} />
  <link rel="alternate" hreflang="en" href={`${siteUrl}/en${routeWithoutLang}`} />
  <link rel="alternate" hreflang="x-default" href={`${siteUrl}/es${routeWithoutLang}`} />

  <!-- Open Graph -->
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />

  <!-- Google Fonts — Playfair Display (serif editorial) + Inter (sans UI) -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Playfair+Display:ital,wght@0,400;0,600;0,700;0,900;1,400;1,700&display=swap" rel="stylesheet">

  <!-- Font Awesome (icons only) -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" crossorigin="anonymous" referrerpolicy="no-referrer">

  <!-- Design System & Global Styles -->
  <link rel="stylesheet" href="/styles/styles.css" />
</head>
<body>
  <slot />

  <!-- Scroll-based nav behaviour -->
  <script>
    const nav = document.querySelector('.site-nav');
    if (nav) {
      const onScroll = () => {
        nav.classList.toggle('scrolled', window.scrollY > 20);
      };
      window.addEventListener('scroll', onScroll, { passive: true });
      onScroll();
    }
  </script>

  <!-- Mobile nav drawer -->
  <script>
    const toggle = document.getElementById('nav-toggle');
    const drawer = document.getElementById('nav-drawer');
    const overlay = document.getElementById('nav-overlay');
    const closeButton = document.getElementById('nav-close');

    const openDrawer = () => {
      toggle?.classList.add('open');
      toggle?.setAttribute('aria-expanded', 'true');
      drawer?.classList.add('open');
      overlay?.classList.add('open');
      document.body.style.overflow = 'hidden';
      // Focus the first link in the drawer
      const firstLink = drawer?.querySelector<HTMLElement>('.nav-drawer-link');
      firstLink?.focus();
    };

    const closeDrawer = () => {
      toggle?.classList.remove('open');
      toggle?.setAttribute('aria-expanded', 'false');
      drawer?.classList.remove('open');
      overlay?.classList.remove('open');
      document.body.style.overflow = '';
      // Return focus to toggle
      toggle?.focus();
    };

    toggle?.addEventListener('click', () => {
      const isOpen = drawer?.classList.contains('open');
      isOpen ? closeDrawer() : openDrawer();
    });

    overlay?.addEventListener('click', closeDrawer);
    closeButton?.addEventListener('click', closeDrawer);

    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape' && drawer?.classList.contains('open')) {
        closeDrawer();
      }
    });

    document.querySelectorAll('.nav-drawer-link').forEach(link => {
      link.addEventListener('click', closeDrawer);
    });
  </script>

  <!-- Scroll-triggered reveal animations -->
  <script>
    const revealEls = document.querySelectorAll('.reveal');
    if (revealEls.length > 0) {
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
            observer.unobserve(entry.target);
          }
        });
      }, { rootMargin: '0px 0px -60px 0px', threshold: 0.08 });

      revealEls.forEach(el => observer.observe(el));
    }
  </script>

  <!-- Premium Lightbox -->
  <script>
    (() => {
      let photos: { src: string; category: string; id: string }[] = [];
      let currentIndex = 0;
      let touchStartX = 0;
      let triggerElement: HTMLElement | null = null;

      const lightbox = document.getElementById('lightbox');
      const lbImg    = document.getElementById('lb-img') as HTMLImageElement | null;
      const lbCat    = document.getElementById('lb-cat');
      const lbCount  = document.getElementById('lb-count');

      if (!lightbox || !lbImg) return;

      // Focus trap: keep Tab cycling within lightbox
      function trapFocus(e: KeyboardEvent) {
        if (e.key !== 'Tab' || !lightbox.classList.contains('open')) return;
        const focusable = lightbox.querySelectorAll<HTMLElement>(
          'button, [href], [tabindex]:not([tabindex="-1"])'
        );
        if (focusable.length === 0) return;
        const first = focusable[0];
        const last = focusable[focusable.length - 1];
        if (e.shiftKey) {
          if (document.activeElement === first) { e.preventDefault(); last.focus(); }
        } else {
          if (document.activeElement === last) { e.preventDefault(); first.focus(); }
        }
      }

      function isVisibleCard(card: HTMLElement) {
        const style = window.getComputedStyle(card);
        return style.display !== 'none' && style.visibility !== 'hidden' && card.getClientRects().length > 0;
      }

      function getGroupCards(group: string) {
        return Array.from(document.querySelectorAll<HTMLElement>('[data-lightbox-src]')).filter((card) => {
          return (card.dataset.lightboxGroup || 'default') === group && isVisibleCard(card);
        });
      }

      function open(index: number) {
        currentIndex = index;
        const p = photos[index];
        if (!p || !lbImg) return;
        lbImg.src = p.src;
        lbImg.alt = p.category;
        if (lbCat) lbCat.textContent = p.category.charAt(0).toUpperCase() + p.category.slice(1);
        if (lbCount) lbCount.textContent = `${index + 1} of ${photos.length}`;
        lightbox.classList.add('open');
        lightbox.setAttribute('aria-hidden', 'false');
        document.body.style.overflow = 'hidden';
        // Focus close button inside lightbox
        const closeBtn = document.getElementById('lb-close');
        closeBtn?.focus();
      }

      function close() {
        lightbox.classList.remove('open');
        lightbox.setAttribute('aria-hidden', 'true');
        document.body.style.overflow = '';
        // Return focus to the card that triggered the lightbox
        triggerElement?.focus();
        triggerElement = null;
      }

      function prev() { open((currentIndex - 1 + photos.length) % photos.length); }
      function next() { open((currentIndex + 1) % photos.length); }

      function activateCard(card: HTMLElement) {
        triggerElement = card;
        const group = card.dataset.lightboxGroup || 'default';
        const cards = getGroupCards(group);
        photos = cards.map((item) => ({
          src: item.dataset.lightboxSrc || '',
          category: item.dataset.lightboxCat || '',
          id: item.dataset.lightboxId || '',
        }));

        const index = cards.findIndex((item) => item === card);
        if (index >= 0) {
          open(index);
        }
      }

      function init() {
        const cards = document.querySelectorAll<HTMLElement>('[data-lightbox-src]');
        cards.forEach((card) => {
          card.addEventListener('click', () => activateCard(card));
          card.addEventListener('keydown', (event) => {
            if (event.key === 'Enter' || event.key === ' ') {
              event.preventDefault();
              activateCard(card);
            }
          });
        });
      }

      // Controls
      document.getElementById('lb-close')?.addEventListener('click', close);
      document.getElementById('lb-prev')?.addEventListener('click', prev);
      document.getElementById('lb-next')?.addEventListener('click', next);

      lightbox.addEventListener('click', (e) => {
        if (e.target === lightbox) close();
      });

      document.addEventListener('keydown', (e) => {
        if (!lightbox.classList.contains('open')) return;
        if (e.key === 'Escape') close();
        if (e.key === 'ArrowLeft') prev();
        if (e.key === 'ArrowRight') next();
        trapFocus(e);
      });

      // Touch / swipe
      lightbox.addEventListener('touchstart', (e) => {
        touchStartX = e.touches[0].clientX;
      }, { passive: true });

      lightbox.addEventListener('touchend', (e) => {
        const delta = touchStartX - e.changedTouches[0].clientX;
        if (Math.abs(delta) > 50) delta > 0 ? next() : prev();
      });

      // Initialize after DOM ready
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', init);
      } else {
        init();
      }
    })();
  </script>

  <!-- Active nav link highlight -->
  <script>
    const currentPath = window.location.pathname;
    document.querySelectorAll('.nav-link, .nav-drawer-link').forEach(link => {
      const href = (link as HTMLAnchorElement).getAttribute('href');
      if (href && (href === currentPath || (href !== '/' && currentPath.startsWith(href)))) {
        link.classList.add('active');
      }
    });
  </script>

  <!-- Google Analytics -->
  <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-5NLFSHDCBJ"></script>
  <script>
    const analyticsWindow = window as unknown as Window & { dataLayer: unknown[][] };
    analyticsWindow.dataLayer = analyticsWindow.dataLayer || [];
    function gtag(...args: unknown[]) { analyticsWindow.dataLayer.push(args); }
    gtag('js', new Date());
    gtag('config', 'G-5NLFSHDCBJ');
  </script>
</body>
</html>
