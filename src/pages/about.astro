---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ContactCTA from '../components/ContactCTA.astro';
import { Image } from 'astro:assets';
import yoImage from '../assets/images/yo.jpg';
---

<BaseLayout title="About" description="Javier Rangel — Photographer based in Mexico City. Portraits, city, concert, and editorial photography.">
  <Header />

  <!-- Hero -->
  <div class="about-hero">
    <div class="about-hero-bg">
      <Image
        src={yoImage}
        alt="Javier Rangel"
        width={1920}
        height={1280}
        loading="eager"
        fetchpriority="high"
      />
    </div>
    <div class="about-hero-overlay"></div>
    <div class="about-hero-content">
      <p class="about-hero-eyebrow">Photographer</p>
      <h1 class="about-hero-title">Behind the Lens</h1>
      <p class="about-hero-sub">Mexico City · Est. 2021</p>
    </div>
  </div>

  <!-- Main content -->
  <main class="about-main">
    <div class="about-grid">
      <!-- Photo -->
      <div class="about-photo-wrap reveal">
        <Image
          src={yoImage}
          alt="Javier Rangel — photographer"
          class="about-photo"
          width={900}
          height={1200}
          loading="eager"
        />
      </div>

      <!-- Text -->
      <div class="about-text reveal stagger-2">
        <h2 class="about-name">Javier Rangel</h2>
        <p class="about-location">Mexico City · Photography</p>

        <div class="about-manifesto">
          <p>
            I'm an amateur photographer based in Mexico City. For me, photography isn't 
            about equipment — it's about seeing. About deciding what to look at, and 
            how long to look.
          </p>
          <p>
            Over the past few years I've explored portraits, urban environments, live 
            concerts, nature, and product work — always searching for the frame where 
            light and moment align.
          </p>
          <p>
            My approach is observational. I'm drawn to quiet details and strong presences: 
            a face in natural light, a street at the edge of night, the energy of a crowd 
            mid-song.
          </p>
          <p>
            Every image I publish is curated. If it's here, I believe in it.
          </p>
        </div>

        <div class="about-services">
          <p class="about-services-title">Available for</p>
          <div class="services-grid">
            <div class="service-item">
              <span class="service-dot"></span>
              <span>Portrait sessions</span>
            </div>
            <div class="service-item">
              <span class="service-dot"></span>
              <span>Concert coverage</span>
            </div>
            <div class="service-item">
              <span class="service-dot"></span>
              <span>Editorial projects</span>
            </div>
            <div class="service-item">
              <span class="service-dot"></span>
              <span>Product photography</span>
            </div>
            <div class="service-item">
              <span class="service-dot"></span>
              <span>Visual collaborations</span>
            </div>
            <div class="service-item">
              <span class="service-dot"></span>
              <span>Select events</span>
            </div>
          </div>
        </div>

        <div class="about-cta">
          <a href="/contact" class="btn btn-primary">Get in Touch</a>
          <a href="/gallery" class="btn btn-ghost">View Archive</a>
        </div>
      </div>
    </div>
  </main>

  <ContactCTA />
  <Footer />
</BaseLayout>
