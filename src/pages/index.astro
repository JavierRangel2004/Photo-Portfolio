---
// SEO & UX optimized Root Redirector
// Using Astro's middleware or server-side functions would be better but this is a static build
---
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>JRMGraphy</title>
  <!-- Basic SEO to tell bots to index the correct localized version -->
  <link rel="canonical" href="https://jrmgraphy.com/es/" />
  <link rel="alternate" hreflang="es" href="https://jrmgraphy.com/es/" />
  <link rel="alternate" hreflang="en" href="https://jrmgraphy.com/en/" />
  <link rel="alternate" hreflang="x-default" href="https://jrmgraphy.com/es/" />
  
  <style>
    body {
      background-color: #0A0A0A;
      color: #fafafa;
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
      display: flex;
      justify-content: center;
      align-items: center;
      height: 100vh;
      margin: 0;
    }
    .loader {
      opacity: 0;
      animation: fadeIn 0.5s ease-in 0.5s forwards;
    }
    @keyframes fadeIn {
      to { opacity: 1; }
    }
  </style>

  <script>
    (function() {
      // 1. Check for saved preference
      const preferred = localStorage.getItem('preferredLang');
      if (preferred === 'en' || preferred === 'es') {
        window.location.replace('/' + preferred + '/');
        return;
      }
      
      // 2. Check for browser language
      const browserLang = navigator.language || (navigator as any).userLanguage;
      if (browserLang && browserLang.toLowerCase().startsWith('en')) {
        window.location.replace('/en/');
      } else {
        // Fallback to default language
        window.location.replace('/es/');
      }
    })();
  </script>
</head>
<body>
  <noscript>
    <meta http-equiv="refresh" content="0;url=/es/" />
  </noscript>
  <div class="loader">
    JRMGraphy
  </div>
</body>
</html>
