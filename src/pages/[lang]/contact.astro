---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { Image } from 'astro:assets';
import yoImage from '../../assets/images/yo.jpg';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';

export function getStaticPaths() {
  return [
    { params: { lang: 'en' } },
    { params: { lang: 'es' } },
  ];
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const inquiryTemplate = lang === 'es'
  ? 'Interesado en: {package}\n\nPresupuesto aproximado:\nFecha o periodo:\nUbicación:\nObjetivo del proyecto:\n'
  : 'Interested in: {package}\n\nEstimated budget:\nDate or time frame:\nLocation:\nProject goal:\n';
---

<BaseLayout title={t('contact.title')} description={t('contact.desc')}>
  <Header />

  <!-- Hero -->
  <div class="contact-hero">
    <div class="contact-hero-bg">
      <Image
        src={yoImage}
        alt="Contact JRMGraphy"
        width={1920}
        height={1280}
        loading="eager"
        fetchpriority="high"
      />
    </div>
    <div class="contact-hero-overlay"></div>
    <div class="contact-hero-content">
      <p class="contact-hero-eyebrow">{t('contact.hero.eyebrow')}</p>
      <h1 class="contact-hero-title">{t('contact.hero.title')}</h1>
      <p class="contact-hero-sub">{t('contact.hero.sub')}</p>
    </div>
  </div>

  <!-- Main content -->
  <main class="contact-main">
    <div class="contact-grid">
      <!-- Info column -->
      <div class="contact-info reveal">
        <h2 class="contact-info-title">{t('contact.info.title')}</h2>
        <p class="contact-info-desc">{t('contact.info.desc')}</p>

        <div class="contact-avail">
          <p class="contact-avail-label">{t('contact.avail.label')}</p>
          <p class="contact-avail-text">{t('contact.avail.text')}</p>
        </div>

        <div class="contact-links">
          <a href="mailto:inspecjrm@gmail.com" class="contact-link">
            <i class="fa fa-envelope" aria-hidden="true"></i>
            inspecjrm@gmail.com
          </a>
          <a
            href="https://www.instagram.com/JRM_Graphy"
            target="_blank"
            rel="noopener noreferrer"
            class="contact-link"
          >
            <i class="fab fa-instagram" aria-hidden="true"></i>
            @JRM_Graphy
          </a>
          <div class="contact-link" style="cursor: default;">
            <i class="fa fa-map-marker-alt" aria-hidden="true"></i>
            Mexico City, Mexico
          </div>
        </div>
      </div>

      <!-- Form column -->
      <div class="contact-form-wrap reveal stagger-2">
        <form
          id="contact-form"
          class="contact-form"
          name="contact"
          method="POST"
          data-netlify="true"
          netlify-honeypot="bot-field"
          data-error-fields={t('contact.form.errorFields')}
          data-error-send={t('contact.form.errorSend')}
        >
          <input type="hidden" name="form-name" value="contact" />
          <p style="display:none;">
            <label>Don't fill this out: <input name="bot-field" /></label>
          </p>

          <div class="form-group">
            <label for="name" class="form-label">{t('contact.form.name')}</label>
            <input
              type="text"
              class="form-input"
              id="name"
              name="name"
              placeholder={t('contact.form.namePlaceholder')}
              required
            />
          </div>

          <div class="form-group">
            <label for="email" class="form-label">{t('contact.form.email')}</label>
            <input
              type="email"
              class="form-input"
              id="email"
              name="email"
              placeholder={t('contact.form.emailPlaceholder')}
              required
            />
          </div>

          <div class="form-group">
            <label for="inquiry-type" class="form-label">{t('contact.form.type')}</label>
            <select id="inquiry-type" name="type" class="form-select" required>
              <option value="">{t('contact.form.typeSelect')}</option>
              <option value="branding">{t('contact.form.typeBranding')}</option>
              <option value="gastronomy">{t('contact.form.typeGastronomy')}</option>
              <option value="events">{t('contact.form.typeEvents')}</option>
              <option value="portraits">{t('contact.form.typePortraits')}</option>
              <option value="archive">{t('contact.form.typeArchive')}</option>
              <option value="general">{t('contact.form.typeGeneral')}</option>
            </select>
          </div>

          <div class="form-group">
            <label for="message" class="form-label">{t('contact.form.message')}</label>
            <textarea
              class="form-textarea"
              id="message"
              name="message"
              rows="5"
              placeholder={t('contact.form.messagePlaceholder')}
              required
            ></textarea>
          </div>

          <div class="form-submit">
            <button type="submit" class="btn btn-primary" id="submit-btn" style="width: 100%;" data-sending={t('contact.form.sending')} data-submit={t('contact.form.submit')}>
              {t('contact.form.submit')}
            </button>
          </div>

          <div class="form-feedback" id="contact-confirmation">
            <i class="fas fa-check-circle"></i>
            <span>{t('contact.form.success')}</span>
          </div>
        </form>
      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const form = document.getElementById('contact-form') as HTMLFormElement;
    const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
    const confirmation = document.getElementById('contact-confirmation');
    const typeSelect = document.getElementById('inquiry-type') as HTMLSelectElement | null;
    const messageField = document.getElementById('message') as HTMLTextAreaElement | null;

    if (!form || !submitBtn) return;

    const search = new URLSearchParams(window.location.search);
    const prefilledType = search.get('type');
    const prefilledPackage = search.get('package');

    if (prefilledType && typeSelect) {
      typeSelect.value = prefilledType;
    }

    if (prefilledPackage && messageField && !messageField.value.trim()) {
      messageField.value = `{inquiryTemplate}`.replace('{package}', prefilledPackage);
    }

    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      const name = (document.getElementById('name') as HTMLInputElement).value.trim();
      const email = (document.getElementById('email') as HTMLInputElement).value.trim();
      const message = (document.getElementById('message') as HTMLTextAreaElement).value.trim();
      const txtSending = submitBtn.dataset.sending || 'Sending…';
      const txtSubmit = submitBtn.dataset.submit || 'Send Message';
      const txtErrorFields = form.dataset.errorFields || 'Please fill out all required fields correctly.';
      const txtErrorSend = form.dataset.errorSend || 'There was a problem sending your message. Please try again.';

      if (!name || !/\S+@\S+\.\S+/.test(email) || !message) {
        alert(txtErrorFields);
        return;
      }

      submitBtn.disabled = true;
      submitBtn.textContent = txtSending;

      const formData = new FormData(form);
      const params = new URLSearchParams();
      for (const [k, v] of formData.entries()) params.append(k, v as string);

      try {
        const res = await fetch('/', {
          method: 'POST',
          headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
          body: params.toString(),
        });
        if (res.ok) {
          form.reset();
          confirmation?.classList.add('show');
        } else {
          throw new Error('Submission failed');
        }
      } catch {
        alert(txtErrorSend);
      } finally {
        submitBtn.disabled = false;
        submitBtn.textContent = txtSubmit;
      }
    });
  });
</script>
