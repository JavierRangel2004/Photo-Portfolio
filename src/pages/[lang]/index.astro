---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Hero from '../../components/Hero.astro';
import FeaturedGallery from '../../components/FeaturedGallery.astro';
import ServiceBlocks from '../../components/ServiceBlocks.astro';
import TrustSignals from '../../components/TrustSignals.astro';
import StatementBlock from '../../components/StatementBlock.astro';
import ContactCTA from '../../components/ContactCTA.astro';
import Modal from '../../components/Modal.astro';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';

export function getStaticPaths() {
  return [
    { params: { lang: 'en' } },
    { params: { lang: 'es' } },
  ];
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<BaseLayout
  title={t('nav.home')}
  description={t('gallery.desc')}
>
  <Header />

  <main>
    <Hero />
    <ServiceBlocks />
    <TrustSignals />
    <FeaturedGallery />
    <StatementBlock />
    <ContactCTA />
  </main>

  <Footer />
  <Modal />
</BaseLayout>
