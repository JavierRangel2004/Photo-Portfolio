---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import ContactCTA from '../../../components/ContactCTA.astro';
import Modal from '../../../components/Modal.astro';
import PhotoCard from '../../../components/PhotoCard.astro';
import {
  getPhotosByGroup,
  getPortfolioGroupIdFromSlug,
  getPortfolioGroups,
  getPortfolioGroupSlug,
} from '../../../lib/photos';
import type { PortfolioGroupId, PortfolioGroupSlug } from '../../../lib/photos';
import { getLangFromUrl, useTranslations, useTranslatedPath } from '../../../i18n/utils';

export function getStaticPaths() {
  const slugs = getPortfolioGroups().map((group) => getPortfolioGroupSlug(group.id));

  return ['en', 'es'].flatMap((lang) =>
    slugs.map((group) => ({
      params: { lang, group },
    })),
  );
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);
const groupSlug = Astro.params.group as PortfolioGroupSlug;
const groupId = getPortfolioGroupIdFromSlug(groupSlug);

if (!groupId) {
  throw new Error(`Unknown gallery group slug: ${groupSlug}`);
}

const groupKeyMap: Record<PortfolioGroupId, string> = {
  branding: 'branding',
  events: 'events',
  'author-archive': 'archive',
};

const key = groupKeyMap[groupId];
const title = t(`portfolio.group.${key}.title` as any);
const description = t(`portfolio.group.${key}.desc` as any);
const label = t(`group.${key}` as any);
const notes = [
  {
    title: t(`portfolio.group.${key}.note1.title` as any),
    body: t(`portfolio.group.${key}.note1.body` as any),
  },
  {
    title: t(`portfolio.group.${key}.note2.title` as any),
    body: t(`portfolio.group.${key}.note2.body` as any),
  },
];

const photos = getPhotosByGroup(groupId);
const navGroups = getPortfolioGroups().map((group) => {
  const navKey = groupKeyMap[group.id];
  return {
    id: group.id,
    href: translatePath(`/gallery/${getPortfolioGroupSlug(group.id)}`),
    label: t(`group.${navKey}` as any),
    active: group.id === groupId,
  };
});
---

<BaseLayout title={title} description={description}>
  <Header />

  <main class="site-main gallery-page gallery-page--group bg-background">
    <div class="gallery-page-header bg-background">
      <div class="container mx-auto w-full max-w-7xl px-6">
        <div class="portfolio-section-header grid grid-cols-1 gap-8 bg-background lg:grid-cols-12 lg:items-start lg:gap-10">
          <div class="portfolio-section-head reveal flex flex-col items-start gap-4 lg:col-span-5">
            <p class="portfolio-section-label">{label}</p>
            <h1 class="gallery-page-title max-w-5xl text-left font-heading text-5xl leading-[1.02] tracking-[-0.02em] text-text lg:text-7xl">
              {title}
            </h1>
            <p class="portfolio-section-description max-w-2xl text-left text-base leading-7 text-text-muted lg:max-w-[32rem]">
              {description}
            </p>
            <div class="portfolio-jump reveal stagger-3 mt-6 flex flex-wrap items-center justify-start gap-3">
              <a
                href={translatePath('/gallery')}
                class="inline-flex min-h-11 items-center rounded-full border border-white/10 px-4 py-2 text-xs uppercase tracking-[0.12em] text-text-muted transition-all duration-base hover:-translate-y-px hover:border-secondary hover:text-text"
              >
                {t('gallery.backToOverview')}
              </a>
              {navGroups.map((group) => (
                <a
                  href={group.href}
                  aria-current={group.active ? 'page' : undefined}
                  class:list={[
                    'inline-flex min-h-11 items-center rounded-full border px-4 py-2 text-xs uppercase tracking-[0.12em] transition-all duration-base hover:-translate-y-px hover:text-text',
                    group.active
                      ? 'border-secondary text-text'
                      : 'border-white/10 text-text-muted hover:border-secondary'
                  ]}
                >
                  {group.label}
                </a>
              ))}
            </div>
          </div>

          <div class="portfolio-notes grid grid-cols-1 gap-8 lg:col-span-7 lg:grid-cols-2">
            {notes.map((note, index) => (
              <article class="portfolio-note reveal border-0 bg-transparent p-0 shadow-none transition-none" style={`transition-delay: ${index * 0.08}s`}>
                <h3 class="mb-3 max-w-[14ch] font-heading text-2xl leading-[1.15] text-text lg:text-[2rem]">
                  {note.title}
                </h3>
                <p class="max-w-[34ch] text-base leading-[1.9] text-text-muted">{note.body}</p>
              </article>
            ))}
          </div>
        </div>
      </div>
    </div>

    <section class="portfolio-section portfolio-section--archive bg-background" id={groupId}>
      <div class="masonry-gallery portfolio-gallery mx-auto w-full max-w-7xl columns-1 gap-4 px-6 sm:columns-2 md:columns-3 xl:columns-4">
        {photos.map((photo, index) => (
          <div class="masonry-item reveal mb-4 break-inside-avoid" style={`transition-delay: ${(index % 4) * 0.06}s`}>
            <PhotoCard
              photo={photo}
              lightboxGroup={groupId}
              label={label}
              loading={index < 6 ? 'eager' : 'lazy'}
              sizes="(min-width: 1600px) 18vw, (min-width: 1200px) 22vw, (min-width: 900px) 30vw, 46vw"
            />
          </div>
        ))}
      </div>
    </section>
  </main>

  <ContactCTA />
  <Footer />
  <Modal />
</BaseLayout>
