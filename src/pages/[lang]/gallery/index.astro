---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import ContactCTA from '../../../components/ContactCTA.astro';
import Modal from '../../../components/Modal.astro';
import PortfolioSection from '../../../components/PortfolioSection.astro';
import { getCuratedPhotosByGroup, getPortfolioGroups, getPortfolioGroupSlug } from '../../../lib/photos';
import type { PortfolioGroupId } from '../../../lib/photos';
import { getLangFromUrl, useTranslations, useTranslatedPath } from '../../../i18n/utils';

export function getStaticPaths() {
  return [
    { params: { lang: 'en' } },
    { params: { lang: 'es' } },
  ];
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);

const groupKeyMap: Record<PortfolioGroupId, string> = {
  branding: 'branding',
  events: 'events',
  'author-archive': 'archive',
};

const sections = getPortfolioGroups().map((group) => {
  const key = groupKeyMap[group.id];

  return {
    id: group.id,
    label: t(`group.${key}` as any),
    title: t(`portfolio.group.${key}.title` as any),
    description: t(`portfolio.group.${key}.desc` as any),
    notes: [
      {
        title: t(`portfolio.group.${key}.note1.title` as any),
        body: t(`portfolio.group.${key}.note1.body` as any),
      },
      {
        title: t(`portfolio.group.${key}.note2.title` as any),
        body: t(`portfolio.group.${key}.note2.body` as any),
      },
    ],
    photos: getCuratedPhotosByGroup(group.id, group.portfolioCount),
    archiveHref: translatePath(`/gallery/${getPortfolioGroupSlug(group.id)}`),
  };
});
---

<BaseLayout
  title={t('gallery.title')}
  description={t('gallery.desc')}
>
  <Header />

  <main class="site-main">
    <div class="gallery-page-header bg-background">
      <div class="container mx-auto w-full max-w-7xl px-6">
        <div class="grid grid-cols-1 gap-8 lg:grid-cols-12 lg:gap-10">
          <div class="gallery-page-copy lg:col-span-10 lg:col-start-1">
            <p class="section-eyebrow reveal text-left">{t('gallery.eyebrow')}</p>
            <h1 class="gallery-page-title reveal stagger-1 max-w-5xl text-left font-heading text-5xl leading-[1.02] tracking-[-0.02em] text-text lg:text-7xl">
              {t('gallery.heading')}
            </h1>
            <p class="gallery-page-subtitle reveal stagger-2 max-w-3xl text-left text-base leading-7 text-text-muted lg:text-lg">
              {t('gallery.subtitle')}
            </p>
            <div class="portfolio-jump reveal stagger-3 mt-6 flex flex-wrap items-center justify-start gap-3">
              <span class="text-xs uppercase tracking-[0.12em] text-text-dim">{t('gallery.jump')}</span>
              {sections.map((section) => (
                <a
                  href={`#${section.id}`}
                  class="inline-flex min-h-11 items-center rounded-full border border-white/10 px-4 py-2 text-xs uppercase tracking-[0.12em] text-text-muted transition-all duration-base hover:-translate-y-px hover:border-secondary hover:text-text"
                >
                  {section.label}
                </a>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="container">
      {sections.length > 0 ? (
        sections.map((section, sectionIdx) => (
          <PortfolioSection
            id={section.id}
            title={section.title}
            description={section.description}
            label={section.label}
            notes={section.notes}
            photos={section.photos}
            sectionIndex={sectionIdx}
            archiveHref={section.archiveHref}
            archiveLabel={t('gallery.viewArchive')}
          />
        ))
      ) : (
        <p style="text-align:center; color: var(--color-text-muted); padding: 4rem 0;">{t('gallery.empty')}</p>
      )}
    </div>
  </main>

  <ContactCTA />
  <Footer />
  <Modal />
</BaseLayout>
