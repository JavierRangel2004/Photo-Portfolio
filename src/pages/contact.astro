---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { Image } from 'astro:assets';
import yoImage from '../assets/images/yo.jpg';
---

<BaseLayout title="Contact" description="Get in touch with Javier Rangel — available for portrait, editorial, concert, and visual collaboration work.">
  <Header />

  <!-- Hero -->
  <div class="contact-hero">
    <div class="contact-hero-bg">
      <Image
        src={yoImage}
        alt="Contact JRMGraphy"
        width={1920}
        height={1280}
        loading="eager"
        fetchpriority="high"
      />
    </div>
    <div class="contact-hero-overlay"></div>
    <div class="contact-hero-content">
      <p class="contact-hero-eyebrow">Let's talk</p>
      <h1 class="contact-hero-title">Get in Touch</h1>
      <p class="contact-hero-sub">Portraits, editorials, live coverage, and visual collaborations shaped around your project.</p>
    </div>
  </div>

  <!-- Main content -->
  <main class="contact-main">
    <div class="contact-grid">
      <!-- Info column -->
      <div class="contact-info reveal">
        <h2 class="contact-info-title">Ready to create something?</h2>
        <p class="contact-info-desc">
          Whether it's a portrait session, editorial project, concert coverage, 
          or a collaboration you have in mind — reach out and let's talk.
        </p>

        <div class="contact-avail">
          <p class="contact-avail-label">Currently available for</p>
          <p class="contact-avail-text">
            Portrait sessions · Concert coverage · Editorial projects · 
            Product photography · Visual collaborations · Select events
          </p>
        </div>

        <div class="contact-links">
          <a href="mailto:inspecjrm@gmail.com" class="contact-link">
            <i class="fa fa-envelope" aria-hidden="true"></i>
            inspecjrm@gmail.com
          </a>
          <a
            href="https://www.instagram.com/JRM_Graphy"
            target="_blank"
            rel="noopener noreferrer"
            class="contact-link"
          >
            <i class="fab fa-instagram" aria-hidden="true"></i>
            @JRM_Graphy
          </a>
          <div class="contact-link" style="cursor: default;">
            <i class="fa fa-map-marker-alt" aria-hidden="true"></i>
            Mexico City, Mexico
          </div>
        </div>
      </div>

      <!-- Form column -->
      <div class="contact-form-wrap reveal stagger-2">
        <form
          id="contact-form"
          class="contact-form"
          name="contact"
          method="POST"
          data-netlify="true"
          netlify-honeypot="bot-field"
        >
          <input type="hidden" name="form-name" value="contact" />
          <p style="display:none;">
            <label>Don't fill this out: <input name="bot-field" /></label>
          </p>

          <div class="form-group">
            <label for="name" class="form-label">Name *</label>
            <input
              type="text"
              class="form-input"
              id="name"
              name="name"
              placeholder="Your name"
              required
            />
          </div>

          <div class="form-group">
            <label for="email" class="form-label">Email *</label>
            <input
              type="email"
              class="form-input"
              id="email"
              name="email"
              placeholder="you@example.com"
              required
            />
          </div>

          <div class="form-group">
            <label for="inquiry-type" class="form-label">Type of inquiry *</label>
            <select id="inquiry-type" name="type" class="form-select" required>
              <option value="">Select a type...</option>
              <option value="portrait">Portrait session</option>
              <option value="concert">Concert coverage</option>
              <option value="editorial">Editorial project</option>
              <option value="product">Product photography</option>
              <option value="collaboration">Visual collaboration</option>
              <option value="general">General inquiry</option>
            </select>
          </div>

          <div class="form-group">
            <label for="message" class="form-label">Message *</label>
            <textarea
              class="form-textarea"
              id="message"
              name="message"
              rows="5"
              placeholder="Tell me about your project…"
              required
            ></textarea>
          </div>

          <div class="form-submit">
            <button type="submit" class="btn btn-primary" id="submit-btn" style="width: 100%;">
              Send Message
            </button>
          </div>

          <div class="form-feedback" id="contact-confirmation">
            <i class="fas fa-check-circle"></i>
            <span>Thank you — I'll be in touch soon.</span>
          </div>
        </form>
      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const form = document.getElementById('contact-form') as HTMLFormElement;
    const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
    const confirmation = document.getElementById('contact-confirmation');

    if (!form) return;

    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      const name = (document.getElementById('name') as HTMLInputElement).value.trim();
      const email = (document.getElementById('email') as HTMLInputElement).value.trim();
      const message = (document.getElementById('message') as HTMLTextAreaElement).value.trim();

      if (!name || !/\S+@\S+\.\S+/.test(email) || !message) {
        alert('Please fill out all required fields correctly.');
        return;
      }

      submitBtn.disabled = true;
      submitBtn.textContent = 'Sending…';

      const formData = new FormData(form);
      const params = new URLSearchParams();
      for (const [k, v] of formData.entries()) params.append(k, v as string);

      try {
        const res = await fetch('/', {
          method: 'POST',
          headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
          body: params.toString(),
        });
        if (res.ok) {
          form.reset();
          confirmation?.classList.add('show');
        } else {
          throw new Error('Submission failed');
        }
      } catch {
        alert('There was a problem sending your message. Please try again.');
      } finally {
        submitBtn.disabled = false;
        submitBtn.textContent = 'Send Message';
      }
    });
  });
</script>
